#version 330 core

in vec2 uv;

out vec4 FragColor;

uniform sampler2D imageTexture;

// Display controls
uniform float uExposure;     // Stops (-10 -> +10)
uniform float uGamma;        // 0.1 -> 5.0
uniform float uBrightness;   // -1 -> +1
uniform float uContrast;     // 0 -> 3
uniform float uSaturation;   // 0 -> 2
uniform float uHue;          // Degrees (-180 -> +180)
uniform float uGain;         // 0 -> 4
uniform float uOffset;       // -1 -> +1

const vec3 LUMA = vec3(0.2126, 0.7152, 0.0722);

vec3 hueRotate(vec3 color, float angle)
{
    float rad = radians(angle);

    float s = sin(rad);
    float c = cos(rad);

    mat3 m = mat3(
        0.213 + c * 0.787 - s * 0.213,
        0.715 - c * 0.715 - s * 0.715,
        0.072 - c * 0.072 + s * 0.928,

        0.213 - c * 0.213 + s * 0.143,
        0.715 + c * 0.285 + s * 0.140,
        0.072 - c * 0.072 - s * 0.283,

        0.213 - c * 0.213 - s * 0.787,
        0.715 - c * 0.715 + s * 0.715,
        0.072 + c * 0.928 + s * 0.072
    );

    return clamp(m * color, 0.0, 1.0);
}

void main()
{
    vec4 color = texture(imageTexture, uv);

    //-------------------------------------------------
    // Exposure (stops)
    //-------------------------------------------------

    color.rgb *= pow(2.0, uExposure);

    //-------------------------------------------------
    // Gain
    //-------------------------------------------------

    color.rgb *= uGain;

    //-------------------------------------------------
    // Offset
    //-------------------------------------------------

    color.rgb += uOffset;

    //-------------------------------------------------
    // Brightness
    //-------------------------------------------------

    color.rgb += uBrightness;

    //-------------------------------------------------
    // Contrast
    //-------------------------------------------------

    color.rgb = (color.rgb - 0.5) * uContrast + 0.5;

    //-------------------------------------------------
    // Saturation
    //-------------------------------------------------

    float luma = dot(color.rgb, LUMA);

    color.rgb = mix(
        vec3(luma),
        color.rgb,
        uSaturation
    );

    //-------------------------------------------------
    // Hue
    //-------------------------------------------------

    color.rgb = hueRotate(color.rgb, uHue);

    //-------------------------------------------------
    // Gamma
    //-------------------------------------------------

    color.rgb = pow(
        max(color.rgb, 0.0),
        vec3(1.0 / uGamma)
    );

    FragColor = vec4(color.rgb, color.a);
}
